# Whitelist mode: everything is ignored by default; only the file types
# below (in any directory) are tracked. A new notebook, slide deck or
# script of an allowed type shows up automatically — no per-file edits
# needed here. Anything not explicitly allowed stays local-only.
*
!*/
!*.ipynb
!*.py
!*.sh
!*.pptx
!*.md
!*.toml
!uv.lock
!*.txt
!.gitignore
!LICENSE

# Local-only build artifacts — share an allowed extension above, so they
# need to be re-ignored explicitly (slide generators and class scripts).
build_slides.py
script.md

# Plantilla de marca del organizador — no es material del curso, no se sube.
_shared/plantilla_csbc26.pptx

# Data and regenerable outputs — never in the repo.
data/
data_bruto/
results/

# Junk / environment — would otherwise be dragged in by !*/.
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.venv/
env/
.DS_Store
Thumbs.db
_archive/
logs/
.atl/
